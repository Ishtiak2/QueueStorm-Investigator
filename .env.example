# QueueStorm Investigator — optional environment configuration.
#
# The default install runs ZERO external services; everything is rule-based.
# Set USE_LLM=1 only if you want the optional LLM polish step enabled.
# All keys are empty by default. Do not commit a filled-in .env file.

# Master switch for the optional LLM text-polish step.
# 0 = off (default, recommended for the hackathon submission)
# 1 = on  (requires an API key below)
USE_LLM=0

# OpenAI — required if USE_LLM=1 and LLM_PROVIDER=openai
OPENAI_API_KEY=

# Anthropic — required if USE_LLM=1 and LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Which provider to call when USE_LLM=1.
# Allowed values: openai | anthropic
LLM_PROVIDER=openai

# Model name passed to the chosen provider.
LLM_MODEL=gpt-4o-mini